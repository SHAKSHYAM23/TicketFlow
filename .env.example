#  Redis
REDIS_URL="redis://localhost:6379"

#  Kafka 
KAFKA_BROKER="localhost:9092"
KAFKA_CLIENT_ID="ticket-booking"
KAFKA_GROUP_ID="ticket-booking-group"

# RabbitMQ
